rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return isAuthenticated() && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }
    
    function isAdmin() {
      return hasUserDoc() && userData().role == 'admin';
    }

    function hasPageAccess(page) {
      return hasUserDoc() &&
        (isAdmin() ||
         ('pages' in userData() && userData().pages.hasAny([page])));
    }

    function hasAnyPageAccess(pageList) {
      return hasUserDoc() &&
        (isAdmin() ||
         ('pages' in userData() && userData().pages.hasAny(pageList)));
    }

    function canSelfEditUserDoc(uid) {
      return isAuthenticated() &&
        request.auth.uid == uid &&
        request.resource.data.uid == resource.data.uid &&
        !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'role',
          'pages',
          'email',
          'uid',
          'isDefaultAdmin',
          'createdAt'
        ]);
    }
    
    // Users collection - document ID MUST be the Firebase Auth UID
    match /users/{uid} {
      // Anyone authenticated can read their own document
      allow read: if isAuthenticated() && request.auth.uid == uid;
      
      // Admins can read all users
      allow read: if isAdmin();
      
      // Only admins can create users
      allow create: if isAdmin() && request.resource.data.uid == uid;
      
      // Users can update a safe subset of their own fields
      allow update: if canSelfEditUserDoc(uid);
      
      // Admins can update any user
      allow update: if isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Vehicles - authenticated staff access only
    match /vehicles/{vehicleId} {
      allow read: if hasAnyPageAccess(['dashboard', 'valet', 'valet-history']);
      allow write: if hasPageAccess('valet');
    }
    
    // Valet history, luggage, amenities - authenticated only
    match /valetHistory/{historyId} {
      allow read: if hasAnyPageAccess(['dashboard', 'valet', 'valet-history']);
      allow write: if hasAnyPageAccess(['valet', 'valet-history']);
    }
    
    match /luggage/{luggageId} {
      allow read: if hasAnyPageAccess(['dashboard', 'luggage', 'luggage-history']);
      allow write: if hasPageAccess('luggage');
    }
    
    match /luggageHistory/{historyId} {
      allow read: if hasAnyPageAccess(['dashboard', 'luggage', 'luggage-history']);
      allow write: if hasAnyPageAccess(['luggage', 'luggage-history']);
    }
    
    match /amenities/{amenityId} {
      allow read: if hasAnyPageAccess(['dashboard', 'amenities', 'amenities-history']);
      allow write: if hasPageAccess('amenities');
    }
    
    match /amenitiesHistory/{historyId} {
      allow read: if hasAnyPageAccess(['dashboard', 'amenities', 'amenities-history']);
      allow write: if hasAnyPageAccess(['amenities', 'amenities-history']);
    }
    
    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /luggageAudit/{auditId} {
      // Restrict read access to luggage staff and admins
      allow read: if hasAnyPageAccess(['luggage', 'luggage-history']);
      
      // Luggage staff and admins can create audit logs
      allow create: if hasAnyPageAccess(['luggage', 'luggage-history']);
      
      // Prevent updates and deletes to maintain audit integrity
      allow update, delete: if false;
    }
    
    // Vehicle Audit Collection
    match /vehicleAudit/{auditId} {
      allow read: if hasAnyPageAccess(['valet', 'valet-history']);
      allow create: if hasAnyPageAccess(['valet', 'valet-history']);
      allow update, delete: if false;
    }

    // Amenities Audit Collection
    match /amenitiesAudit/{auditId} {
      allow read: if hasAnyPageAccess(['amenities', 'amenities-history']);
      allow create: if hasAnyPageAccess(['amenities', 'amenities-history']);
      allow update, delete: if false;
    }

    // Password Reset Collection - Backend only (Firebase Admin)
    match /passwordResets/{resetId} {
      // Clients cannot read, write, or delete password reset documents
      // All operations are done server-side via Firebase Admin SDK
      allow read, write, delete: if false;
    }

    // Audit Logs Collection
    match /auditLogs/{auditId} {
      // Only admins can read security audit logs
      allow read: if isAdmin();
      // Only backend (Firebase Admin) can write
      allow create: if false;
      // Prevent updates and deletes to maintain audit integrity
      allow update, delete: if false;
    }

    // Contractors (currently signed in on site)
    match /contractors/{contractorId} {
      allow read, write: if hasAnyPageAccess(['maintenance', 'maintenance/contractor-sign-in', 'maintenance/jobs']);
    }

    // Contractor sign-out history
    match /contractorHistory/{historyId} {
      allow read, write: if hasAnyPageAccess(['maintenance', 'maintenance/contractor-sign-in', 'maintenance/jobs']);
    }

    // Maintenance jobs
    match /maintenanceJobs/{jobId} {
      allow read, write: if hasAnyPageAccess(['maintenance', 'maintenance/jobs']);
    }

    // Login tokens — only writable by the server (Firebase Admin SDK bypasses these rules).
    // Explicitly deny all direct client access as a defence-in-depth measure.
    match /loginTokens/{tokenId} {
      allow read, write: if false;
    }

    // AP invoices: authenticated users can read/update, only server can create
    match /ap_invoices/{invoiceId} {
      allow read, update: if hasPageAccess('accounts-payable');
      allow create: if false; // only Firebase Admin (server) can create
      allow delete: if false;
    }
    // Travel agent database - read by authenticated staff, write requires page access
    match /travel_agents/{docId} {
      allow read: if hasAnyPageAccess(['accounts-payable', 'accounts-payable/travel-agents']);
      allow write: if hasAnyPageAccess(['accounts-payable', 'accounts-payable/travel-agents']);
    }

    // Supplier database - read by authenticated staff, write requires page access
    match /ap_suppliers/{docId} {
      allow read: if hasAnyPageAccess(['accounts-payable', 'accounts-payable/suppliers']);
      allow write: if hasAnyPageAccess(['accounts-payable', 'accounts-payable/suppliers']);
    }
  }
}